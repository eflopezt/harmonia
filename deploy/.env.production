# ============================================================================
# Harmoni ERP — Production Environment Variables
# Copiar a /opt/harmoni/app/.env.production y rellenar los valores
# ============================================================================

# Django
DJANGO_SECRET_KEY=CAMBIAR-genera-con-python-c-from-django.core.management.utils-import-get_random_secret_key-print-get_random_secret_key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=harmoni.pe,www.harmoni.pe,nexotalent.pe,www.nexotalent.pe,212.56.34.166
DJANGO_SETTINGS_MODULE=config.settings.production

# Database (PostgreSQL en el host)
DATABASE_URL=postgresql://harmoni:CAMBIAR_PASSWORD@host.docker.internal:5432/harmoni_db

# Redis (en el host)
REDIS_URL=redis://:CAMBIAR_PASSWORD@host.docker.internal:6379/0
CELERY_BROKER_URL=redis://:CAMBIAR_PASSWORD@host.docker.internal:6379/0
CELERY_RESULT_BACKEND=redis://:CAMBIAR_PASSWORD@host.docker.internal:6379/1

# CSRF / CORS
CSRF_TRUSTED_ORIGINS=https://harmoni.pe,https://www.harmoni.pe,https://nexotalent.pe,https://www.nexotalent.pe
CORS_ALLOWED_ORIGINS=https://harmoni.pe,https://nexotalent.pe

# Sentry (opcional)
SENTRY_DSN=

# AI Providers (rellenar con tus API keys)
GOOGLE_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
